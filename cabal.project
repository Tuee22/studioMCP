packages: .

with-compiler: ghc

-- GHC 9.14.1 is new; many packages need allow-newer for base 4.22 and template-haskell 2.24
allow-newer:
  , *:base
  , *:template-haskell
  , *:ghc-prim
  , *:ghc-bignum

-- Build artifacts must stay outside the repository tree.
-- The outer container and all reasonable CLI commands target /opt/build/.
builddir: /opt/build/studiomcp
